# ── Обязательно заполни ──────────────────────────────────────────────────────
BOT_TOKEN=your_bot_token_here

# Твой Telegram user_id (получи через @userinfobot)
ADMIN_IDS=5762973275

# ── Платёжные настройки ───────────────────────────────────────────────────────
TON_WALLET=your_ton_wallet_address
TON_API_KEY=your_toncenter_api_key

# ── Бизнес-настройки ─────────────────────────────────────────────────────────
# Комиссия маркета (0.03 = 3%)
MARKET_FEE=0.03

# Реферальный бонус (0.01 = 1%)
REFERRAL_BONUS_PERCENT=0.01

# Минимальная цена листинга в TON
MIN_PRICE_TON=0.1

# ── База данных ───────────────────────────────────────────────────────────────
# SQLite (по умолчанию, для старта)
DATABASE_URL=sqlite+aiosqlite:///nft_market.db

# PostgreSQL (для продакшена, раскомментируй)
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/nft_market
